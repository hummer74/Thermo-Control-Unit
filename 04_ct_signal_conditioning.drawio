<mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="500">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
    <mxCell id="TITLE" value="Цепь токового датчика - подробная схема" style="text;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="250" y="10" width="400" height="30" as="geometry" /></mxCell>

    <!-- CT Primary (power line) -->
    <mxCell id="PWR_IN" value="От ТЭН&lt;br&gt;(фаза 220V)" style="text;fontSize=11;fontStyle=1;fontColor=#CC0000;" vertex="1" parent="1"><mxGeometry x="10" y="50" width="90" height="35" as="geometry" /></mxCell>
    <mxCell id="PWR_OUT" value="К сети&lt;br&gt;220V" style="text;fontSize=11;fontStyle=1;fontColor=#CC0000;" vertex="1" parent="1"><mxGeometry x="230" y="50" width="90" height="35" as="geometry" /></mxCell>
    <mxCell id="CT_CORE" value="CT SCT-013&lt;br&gt;1000:1&lt;br&gt;(надевается&lt;br&gt;на провод)" style="ellipse;whiteSpace=wrap;html=1;strokeWidth=3;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1"><mxGeometry x="110" y="35" width="110" height="90" as="geometry" /></mxCell>

    <!-- Power line through CT -->
    <mxCell id="pw1" edge="1" parent="1" style="strokeWidth=3;strokeColor=#CC0000;exitX=0;exitY=0.5;entryX=0;entryY=0.5;"><mxGeometry relative="1" as="geometry"><mxPoint x="100" y="67" as="sourcePoint" /><mxPoint x="110" y="67" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="pw2" edge="1" parent="1" style="strokeWidth=3;strokeColor=#CC0000;"><mxGeometry relative="1" as="geometry"><mxPoint x="220" y="67" as="sourcePoint" /><mxPoint x="230" y="67" as="targetPoint" /></mxGeometry></mxCell>

    <!-- CT Secondary output -->
    <mxCell id="CT_SEC1" value="" style="ellipse;fillColor=#333;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="155" y="130" width="8" height="8" as="geometry" /></mxCell>
    <mxCell id="CT_SEC2" value="" style="ellipse;fillColor=#333;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="175" y="130" width="8" height="8" as="geometry" /></mxCell>
    <mxCell id="CT_L1" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="159" y="125" as="sourcePoint" /><mxPoint x="159" y="130" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="CT_L2" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="179" y="125" as="sourcePoint" /><mxPoint x="179" y="130" as="targetPoint" /></mxGeometry></mxCell>

    <!-- Burden Resistor -->
    <mxCell id="RB" value="Rb&lt;br&gt;100 Ом&lt;br&gt;(1/4W)" style="resistor;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="130" y="155" width="90" height="30" as="geometry" /></mxCell>
    <mxCell id="ct_rb1" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="159" y="138" as="sourcePoint" /><mxPoint x="145" y="155" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="ct_rb2" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="179" y="138" as="sourcePoint" /><mxPoint x="205" y="155" as="targetPoint" /></mxGeometry></mxCell>

    <!-- Junction point -->
    <mxCell id="J1" value="" style="ellipse;fillColor=#333;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="200" y="250" width="8" height="8" as="geometry" /></mxCell>
    <mxCell id="rb_j1" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="205" y="185" as="sourcePoint" /><mxPoint x="204" y="250" as="targetPoint" /></mxGeometry></mxCell>

    <!-- Bridge Rectifier -->
    <mxCell id="BRIDGE" value="" style="shape=mxgraph.basic.pentagon;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#e1d5e7;strokeColor=#9673a6;direction=south;size=15;" vertex="1" parent="1"><mxGeometry x="280" y="175" width="100" height="80" as="geometry" /></mxCell>
    <mxCell id="BR_T" value="Диодный мост&lt;br&gt;W04M" style="text;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="270" y="140" width="120" height="30" as="geometry" /></mxCell>
    <mxCell id="BR_AC1" value="~" style="text;fontSize=12;fontStyle=1;align=center;fontColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="285" y="195" width="20" height="20" as="geometry" /></mxCell>
    <mxCell id="BR_AC2" value="~" style="text;fontSize=12;fontStyle=1;align=center;fontColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="355" y="195" width="20" height="20" as="geometry" /></mxCell>
    <mxCell id="BR_PLUS" value="+" style="text;fontSize=14;fontStyle=1;align=center;fontColor=#CC0000;" vertex="1" parent="1"><mxGeometry x="318" y="175" width="20" height="20" as="geometry" /></mxCell>
    <mxCell id="BR_MINUS" value="-" style="text;fontSize=14;fontStyle=1;align=center;fontColor=#0066CC;" vertex="1" parent="1"><mxGeometry x="318" y="240" width="20" height="20" as="geometry" /></mxCell>

    <!-- CT to Bridge connections -->
    <mxCell id="ct_br1" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="145" y="185" as="sourcePoint" /><mxPoint x="145" y="210" /><mxPoint x="280" y="210" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="ct_br2" style="strokeWidth=1.5;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="204" y="254" as="sourcePoint" /><mxPoint x="260" y="254" /><mxPoint x="260" y="220" /><mxPoint x="280" y="220" as="targetPoint" /></mxGeometry></mxCell>

    <!-- Filter Capacitor -->
    <mxCell id="CAP" value="C&lt;br&gt;10 мкФ&lt;br&gt;25V" style="ellipse;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1"><mxGeometry x="430" y="185" width="65" height="65" as="geometry" /></mxCell>

    <!-- Bridge to Cap -->
    <mxCell id="br_cap_p" style="strokeWidth=2;strokeColor=#CC0000;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="380" y="210" as="sourcePoint" /><mxPoint x="462" y="210" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="br_cap_n" style="strokeWidth=2;strokeColor=#0066CC;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="380" y="220" as="sourcePoint" /><mxPoint x="430" y="220" /><mxPoint x="430" y="250" as="targetPoint" /></mxGeometry></mxCell>

    <!-- Trimmer Potentiometer -->
    <mxCell id="POT" value="Подстроечный&lt;br&gt;резистор&lt;br&gt;10 кОм" style="verticalLabelPosition=bottom;shadow=0;dashed=0;align=center;html=1;verticalAlign=top;fontSize=10;shape=mxgraph.electrical.resistors.potentiometer_2;strokeWidth=2;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="570" y="180" width="80" height="100" as="geometry" /></mxCell>

    <!-- Cap to Pot -->
    <mxCell id="cap_pot" style="strokeWidth=2;strokeColor=#333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="495" y="217" as="sourcePoint" /><mxPoint x="570" y="217" as="targetPoint" /></mxGeometry></mxCell>

    <!-- ADC Output -->
    <mxCell id="ADC_OUT" value="ESP-32&lt;br&gt;ADC_IN&lt;br&gt;(0-3.3V)" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontStyle=1;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="730" y="190" width="120" height="65" as="geometry" /></mxCell>

    <!-- Pot to ADC -->
    <mxCell id="pot_adc" value="Аналоговый&lt;br&gt;выход 0-3.3V" style="strokeWidth=2;strokeColor=#009900;rounded=1;fontSize=9;fontStyle=2;fontColor=#009900;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="230" as="sourcePoint" /><mxPoint x="730" y="222" as="targetPoint" /></mxGeometry></mxCell>

    <!-- GND connections -->
    <mxCell id="GND1" value="GND" style="shape=mxgraph.basic.smiley;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=0;fillColor=#CCCCCC;fontSize=8;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="462" y="265" width="30" height="30" as="geometry" /></mxCell>
    <mxCell id="GND_CAP" style="strokeWidth=1;strokeColor=#0066CC;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="477" y="265" as="sourcePoint" /><mxPoint x="477" y="250" as="targetPoint" /></mxGeometry></mxCell>

    <!-- GND for pot -->
    <mxCell id="GND2" value="GND" style="shape=mxgraph.basic.smiley;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=0;fillColor=#CCCCCC;fontSize=8;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="600" y="300" width="30" height="30" as="geometry" /></mxCell>

    <!-- Annotations -->
    <mxCell id="N1" value="1. CT измеряет ток&lt;br&gt;2. Rb преобразует в&lt;br&gt;   напряжение&lt;br&gt;3. Мост выпрямляет&lt;br&gt;4. C фильтрует пульсации&lt;br&gt;5. Radj подстраивает&lt;br&gt;   диапазон для ADC" style="text;fontSize=10;align=left;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="30" y="350" width="200" height="110" as="geometry" /></mxCell>

    <mxCell id="N2" value="Расчёт:&lt;br&gt;ТЭН 1 кВт / 220В = 4.55А&lt;br&gt;CT 1000:1 =&gt; 4.55 мА вторичный&lt;br&gt;Rb 100 Ом =&gt; 0.455В (AC)&lt;br&gt;После моста: ~0.64V (пик)&lt;br&gt;Radj делит до 0-3.3V для ADC" style="text;fontSize=10;align=left;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="530" y="350" width="250" height="110" as="geometry" /></mxCell>
  </root>
</mxGraphModel>