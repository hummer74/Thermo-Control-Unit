<mxGraphModel dx="1100" dy="750" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1050" pageHeight="700">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
    <mxCell id="TITLE" value="Диаграмма состояний - Контроль одного канала ТЭН" style="text;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="250" y="10" width="500" height="30" as="geometry" /></mxCell>

    <!-- States -->
    <!-- IDLE -->
    <mxCell id="ST_IDLE" value="&lt;b&gt;IDLE&lt;/b&gt;&lt;br&gt;Реле ВЫКЛ&lt;br&gt;LED: нет" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;arcSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="200" width="140" height="80" as="geometry" /></mxCell>

    <!-- HEATING -->
    <mxCell id="ST_HEAT" value="&lt;b&gt;HEATING&lt;/b&gt;&lt;br&gt;Реле ВКЛ&lt;br&gt;LED: Жёлтый&lt;br&gt;Темп &lt; 435C" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=15;" vertex="1" parent="1"><mxGeometry x="300" y="200" width="150" height="90" as="geometry" /></mxCell>

    <!-- IN_RANGE -->
    <mxCell id="ST_RANGE" value="&lt;b&gt;IN_RANGE&lt;/b&gt;&lt;br&gt;Реле циклично&lt;br&gt;LED: Зелёный&lt;br&gt;435-450 C" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=15;" vertex="1" parent="1"><mxGeometry x="560" y="200" width="150" height="90" as="geometry" /></mxCell>

    <!-- COOLING -->
    <mxCell id="ST_COOL" value="&lt;b&gt;COOLING&lt;/b&gt;&lt;br&gt;Реле ВЫКЛ&lt;br&gt;LED: Зелёный&lt;br&gt;Ожидание &lt; 435C" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=15;" vertex="1" parent="1"><mxGeometry x="810" y="200" width="150" height="90" as="geometry" /></mxCell>

    <!-- FAULT -->
    <mxCell id="ST_FAULT" value="&lt;b&gt;FAULT&lt;/b&gt;&lt;br&gt;Реле ВЫКЛ (авария)&lt;br&gt;LED: Красный&lt;br&gt;Нет тока при ВКЛ" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;arcSize=15;" vertex="1" parent="1"><mxGeometry x="420" y="450" width="170" height="100" as="geometry" /></mxCell>

    <!-- THERMO_ERR -->
    <mxCell id="ST_TERR" value="&lt;b&gt;THERMO_ERR&lt;/b&gt;&lt;br&gt;Ошибка&lt;br&gt;термопары&lt;br&gt;LED: нет" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;arcSize=15;dashed=1;" vertex="1" parent="1"><mxGeometry x="60" y="450" width="150" height="100" as="geometry" /></mxCell>

    <!-- Start marker -->
    <mxCell id="START" value="" style="ellipse;fillColor=#000000;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="120" y="100" width="20" height="20" as="geometry" /></mxCell>
    <mxCell id="START_L" value="START" style="text;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="90" y="80" width="80" height="20" as="geometry" /></mxCell>

    <!-- Transitions -->
    <!-- START -> IDLE -->
    <mxCell id="T_START" value="" style="strokeWidth=2;strokeColor=#333;" edge="1" parent="1" source="START" target="ST_IDLE"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- IDLE -> HEATING -->
    <mxCell id="T1" value="Целевая&lt;br&gt;температура&lt;br&gt;задана" style="strokeWidth=2;strokeColor=#333;rounded=1;fontSize=9;fontStyle=2;" edge="1" parent="1" source="ST_IDLE" target="ST_HEAT"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- HEATING -> IN_RANGE -->
    <mxCell id="T2" value="T &gt;= 435C&lt;br&gt;(LOW_THRESH)" style="strokeWidth=2;strokeColor=#009900;rounded=1;fontSize=9;fontStyle=2;fontColor=#009900;" edge="1" parent="1" source="ST_HEAT" target="ST_RANGE"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- HEATING -> FAULT -->
    <mxCell id="T3" value="Реле ВКЛ&lt;br&gt;но ток = 0&lt;br&gt;(FAULT_DELAY)" style="strokeWidth=2;strokeColor=#CC0000;rounded=1;fontSize=9;fontStyle=2;fontColor=#CC0000;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="ST_HEAT" target="ST_FAULT"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- IN_RANGE -> COOLING -->
    <mxCell id="T4" value="T &gt;= 450C&lt;br&gt;(HIGH_THRESH)&lt;br&gt;Реле ВЫКЛ" style="strokeWidth=2;strokeColor=#0066CC;rounded=1;fontSize=9;fontStyle=2;fontColor=#0066CC;" edge="1" parent="1" source="ST_RANGE" target="ST_COOL"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- COOLING -> HEATING -->
    <mxCell id="T5" value="T &lt; 435C&lt;br&gt;Реле ВКЛ" style="strokeWidth=2;strokeColor=#333;rounded=1;fontSize=9;fontStyle=2;exitX=0.5;exitY=0;entryX=1;entryY=0;" edge="1" parent="1" source="ST_COOL" target="ST_HEAT"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="885" y="100" /><mxPoint x="450" y="100" /></Array></mxGeometry></mxCell>

    <!-- IN_RANGE -> HEATING -->
    <mxCell id="T6" value="T &lt; 435C&lt;br&gt;Реле ВКЛ" style="strokeWidth=2;strokeColor=#333;rounded=1;fontSize=9;fontStyle=2;exitX=0.5;exitY=0;entryX=0.5;entryY=0;" edge="1" parent="1" source="ST_RANGE" target="ST_HEAT"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="635" y="100" /></Array></mxGeometry></mxCell>

    <!-- FAULT -> IDLE (RESET) -->
    <mxCell id="T7" value="RESET&lt;br&gt;(команда)" style="strokeWidth=2;strokeColor=#9673a6;rounded=1;fontSize=9;fontStyle=2;fontColor=#9673a6;dashed=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="ST_FAULT" target="ST_IDLE"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="130" y="500" /></Array></mxGeometry></mxCell>

    <!-- THERMO_ERR -> IDLE (RESET) -->
    <mxCell id="T8" value="RESET" style="strokeWidth=1.5;strokeColor=#9673a6;rounded=1;fontSize=9;fontStyle=2;fontColor=#9673a6;dashed=1;exitX=0.5;exitY=0;entryX=0;entryY=1;" edge="1" parent="1" source="ST_TERR" target="ST_IDLE"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="35" y="350" /></Array></mxGeometry></mxCell>

    <!-- Any -> THERMO_ERR -->
    <mxCell id="T9" value="Считывание&lt;br&gt;термопары = 0&lt;br&gt;(обрыв)" style="strokeWidth=1.5;strokeColor=#CC0000;rounded=1;fontSize=9;fontStyle=2;fontColor=#CC0000;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ST_HEAT" target="ST_TERR"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="200" y="400" /></Array></mxGeometry></mxCell>

    <!-- IDLE -> HEATING (after RESET from COOLING) -->
    <mxCell id="T10" value="STOP ALL&lt;br&gt;(команда)" style="strokeWidth=1.5;strokeColor=#9673a6;rounded=1;fontSize=9;fontStyle=2;fontColor=#9673a6;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry">
      <mxPoint x="635" y="290" as="sourcePoint" />
      <mxPoint x="130" y="245" as="targetPoint" />
      <Array as="points"><mxPoint x="635" y="370" /><mxPoint x="35" y="370" /></Array>
    </mxGeometry></mxCell>

    <!-- Parameter annotations -->
    <mxCell id="PARAMS" value="Параметры:&lt;br&gt;HIGH_THRESH = 450C (выключение)&lt;br&gt;LOW_THRESH = 435C (включение)&lt;br&gt;Гистерезис = 15C&lt;br&gt;READ_INTERVAL = 500 мс&lt;br&gt;FAULT_DELAY = 3000 мс&lt;br&gt;CURRENT_THRESH = 100 ADC" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=10;fillColor=#f5f5f5;strokeColor=#CCCCCC;align=left;" vertex="1" parent="1"><mxGeometry x="700" y="430" width="250" height="120" as="geometry" /></mxCell>

    <!-- Legend -->
    <mxCell id="LEGEND" value="Легенда:" style="text;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="700" y="380" width="80" height="20" as="geometry" /></mxCell>
    <mxCell id="LE1" value="--- Нормальные переходы" style="text;fontSize=10;fontColor=#333;" vertex="1" parent="1"><mxGeometry x="700" y="400" width="180" height="18" as="geometry" /></mxCell>
    <mxCell id="LE2" value="-- - Переходы по команде / ошибка" style="text;fontSize=10;fontColor=#CC0000;" vertex="1" parent="1"><mxGeometry x="700" y="418" width="230" height="18" as="geometry" /></mxCell>
  </root>
</mxGraphModel>